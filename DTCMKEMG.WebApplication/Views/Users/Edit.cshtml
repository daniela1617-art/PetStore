@model DTCMKEMG.BusinessLogic.DTOs.UpdateUserRequest

@{
    ViewData["Title"] = "Editar";
}

<h1>Editar</h1>

<h4>Usuarios</h4>

<hr />

<form asp-action="Edit">

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <input asp-for="Id" type="hidden" />

    <div class="row">

        <div class="form-group col-6">
            <label asp-for="Username" class="control-label">
                Usuario
            </label>

            <input asp-for="Username" class="form-control" />

            <span asp-validation-for="Username" class="text-danger"></span>
        </div>

        <div class="form-group col-6">
            <label asp-for="RoleId" class="control-label">
                Rol
            </label>

            <select asp-for="RoleId"
                    class="form-control"
                    asp-items="ViewBag.RoleId">
            </select>

            <span asp-validation-for="RoleId" class="text-danger"></span>
        </div>

        <div class="form-group col-6 mt-3">
            <label asp-for="PasswordHash" class="control-label">
                Password
            </label>

            <input asp-for="PasswordHash"
                   type="password"
                   class="form-control" />

            <span asp-validation-for="PasswordHash" class="text-danger"></span>
        </div>

        <div class="row">
            <div class="form-group mt-3">

                <input type="submit"
                       value="Guardar"
                       class="btn btn-primary" />

                <a asp-action="Index"
                       class="btn btn-info">
                    Cancelar
                </a>

            </div>
        </div>

    </div>

</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}