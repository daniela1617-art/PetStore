@model DTCMKEMG.BusinessLogic.DTOs.RoleResponse

@{
    ViewData["Title"] = "Eliminar";
}

<h1>Eliminar Rol</h1>

<h3>¿Deseas eliminar este rol?</h3>

<div>
    <hr />

    <dl class="row">
        <dt class="col-sm-2">
            Id
        </dt>

        <dd class="col-sm-10">
            @Model.Id
        </dd>

        <dt class="col-sm-2">
            Nombre
        </dt>

        <dd class="col-sm-10">
            @Model.Name
        </dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />

        <button type="submit" class="btn btn-danger">
            Eliminar
        </button>

        <a asp-action="Index" class="btn btn-secondary">
            Volver
        </a>
    </form>
</div>