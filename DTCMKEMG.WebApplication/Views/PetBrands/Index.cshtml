@model IList<DTCMKEMG.BusinessLogic.DTOs.PetBrandResponse>
@{
    ViewData["Title"] = "Marcas";
}
<h1>Raza de Mascotas</h1>

<p>
    <a asp-action="Create" class="btn btn-info">Ir a crear raza</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                Nombre
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.Name)
                </td>
                <td>
                    @Html.ActionLink("Editar", "Edit", new { id = item.Id }, new { @class = "btn btn-success" })
                    @Html.ActionLink("Eliminar", "Delete", new { id = item.Id }, new { @class = "btn btn-danger" })
                </td>
            </tr>
        }
    </tbody>
</table>
